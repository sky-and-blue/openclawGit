{"type":"message","id":"85d3dbd9","parentId":"a7efde6d","timestamp":"2026-03-18T05:49:19.658Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"我已经创建了基本的技能结构，但还需要创建实际的工具脚本文件。让我创建主要的脚本文件来处理 IMA API 调用。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"write:43","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/ima-skills/ima_api.sh","content":"#!/bin/bash\n# IMA API 调用辅助脚本\n\n# 检查环境变量\nif [ -z \"$IMA_OPENAPI_CLIENTID\" ] || [ -z \"$IMA_OPENAPI_APIKEY\" ]; then\n    echo '{\"error\": \"缺少 IMA 凭证，请设置环境变量 IMA_OPENAPI_CLIENTID 和 IMA_OPENAPI_APIKEY\"}'\n    exit 1\nfi\n\nBASE_URL=\"https://ima.qq.com/openapi/note/v1\"\n\n# 调用 API 的通用函数\nima_api() {\n    local endpoint=\"$1\"\n    local body=\"${2:-{}}\"\n    \n    curl -s -X POST \"${BASE_URL}/${endpoint}\" \\\n        -H \"ima-openapi-clientid: $IMA_OPENAPI_CLIENTID\" \\\n        -H \"ima-openapi-apikey: $IMA_OPENAPI_APIKEY\" \\\n        -H \"Content-Type: application/json\" \\\n        -d \"$body\"\n}\n\n# 根据参数执行对应操作\ncase \"$1\" in\n    search)\n        # 搜索笔记: $2 = search_type, $3 = query, $4 = start, $5 = end\n        ima_api \"search_note_book\" \"{\\\"search_type\\\": $2, \\\"query_info\\\": {\\\"title\\\": \\\"$3\\\", \\\"content\\\": \\\"$3\\\"}, \\\"start\\\": ${4:-0}, \\\"end\\\": ${5:-20}}\"\n        ;;\n    list_folders)\n        # 列出笔记本: $2 = cursor, $3 = limit\n        ima_api \"list_note_folder_by_cursor\" \"{\\\"cursor\\\": \\\"${2:-0}\\\", \\\"limit\\\": ${3:-20}}\"\n        ;;\n    list_notes)\n        # 列出笔记: $2 = folder_id, $3 = cursor, $4 = limit\n        ima_api \"list_note_by_folder_id\" \"{\\\"folder_id\\\": \\\"$2\\\", \\\"cursor\\\": \\\"${3:-}\\\", \\\"limit\\\": ${4:-20}}\"\n        ;;\n    read)\n        # 读取笔记: $2 = doc_id\n        ima_api \"get_doc_content\" \"{\\\"doc_id\\\": \\\"$2\\\", \\\"target_content_format\\\": 0}\"\n        ;;\n    create)\n        # 创建笔记: $2 = content, $3 = folder_id(可选)\n        if [ -n \"$3\" ]; then\n            ima_api \"import_doc\" \"{\\\"content_format\\\": 1, \\\"content\\\": \\\"$2\\\", \\\"folder_id\\\": \\\"$3\\\"}\"\n        else\n            ima_api \"import_doc\" \"{\\\"content_format\\\": 1, \\\"content\\\": \\\"$2\\\"}\"\n        fi\n        ;;\n    append)\n        # 追加内容: $2 = doc_id, $3 = content\n        ima_api \"append_doc\" \"{\\\"doc_id\\\": \\\"$2\\\", \\\"content_format\\\": 1, \\\"content\\\": \\\"$3\\\"}\"\n        ;;\n    *)\n        echo '{\"error\": \"未知操作: '$1'\", \"usage\": \"search|list_folders|list_notes|read|create|append\"}'\n        exit 1\n        ;;\nesac\n"}}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773812893334}}
