hrome for Testing Framework.framework/Versions/145.0.7632.6/Libraries/libvk_swiftshader.dylib\n/Users/liyue/Library/Caches/ms-playwright/chromium-1208/chrome-mac-arm64/Google Chrome for Testing.app/Contents/Frameworks/Google Chrome for Testing Framework.framework/Versions/145.0.7632.6/Libraries/libGLESv2.dylib","cwd":"/Users/liyue/.openclaw/workspace"},"isError":false,"timestamp":1773722536945}}
